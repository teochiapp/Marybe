{
  "kind": "collectionType",
  "collectionName": "productos",
  "info": {
    "singularName": "producto",
    "pluralName": "productos",
    "displayName": "Producto",
    "description": "Catálogo de productos de Marybe con variantes anidadas"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nombre": {
      "type": "string",
      "required": true
    },
    "id_original": {
      "type": "string"
    },
    "sku": {
      "type": "string"
    },
    "marca": {
      "type": "string"
    },
    "seccion": {
      "type": "string"
    },
    "subcategoria": {
      "type": "string"
    },
    "tipo": {
      "type": "string"
    },
    "categoria": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::categoria.categoria",
      "inversedBy": "productos"
    },
    "descripcion": {
      "type": "text"
    },
    "especificaciones": {
      "type": "text"
    },
    "proveedor": {
      "type": "string"
    },
    "publicado": {
      "type": "boolean",
      "default": true
    },
    "variantes": {
      "type": "component",
      "component": "producto.variante",
      "repeatable": true
    },
    "portada": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "destacado": {
      "type": "boolean",
      "default": false
    },
    "descuento": {
      "type": "integer",
      "default": 0
    },
    "galeria": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "caracteristicas": {
      "type": "text"
    },
    "precio": {
      "type": "decimal"
    },
    "precio_oferta": {
      "type": "decimal"
    },
    "stock": {
      "type": "integer",
      "default": 0
    }
  }
}
