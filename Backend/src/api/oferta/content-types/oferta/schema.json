{
  "kind": "collectionType",
  "collectionName": "ofertas",
  "info": {
    "singularName": "oferta",
    "pluralName": "ofertas",
    "displayName": "Oferta",
    "description": "Sección de ofertas promocionales para el home"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titulo": {
      "type": "string",
      "required": true
    },
    "enlace": {
      "type": "string"
    },
    "imagen": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "tamano": {
      "type": "integer",
      "default": 100,
      "min": 10,
      "max": 100
    },
    "seccion": {
      "type": "enumeration",
      "enum": [
        "Perfumería",
        "Hogar"
      ],
      "default": "Perfumería"
    },
    "orden": {
      "type": "integer",
      "default": 0,
      "min": 0
    }
  }
}
